{
    "manifest_version": 3,
    "name": "Docflow Chrome Connector",
    "description": "Docflows koppling till Swedbank för BG/PG-uppslag.",
    "version": "1.0.0",
    "key": "",
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "https://online.swedbank.se/*",
        "https://www.swedbank.se/*"
    ],
    "externally_connectable": {
        "matches": [
            "http://127.0.0.1:4321/*"
        ]
    }
}
